{
  "_meta": {
    "description": "SGA DevOps Setup Configuration — Complete blueprint to replicate this development environment",
    "project": "Sistema Global Armonizado (SGA) — GHS Label System",
    "repository": "https://github.com/Charly-bite/SGA_v1.0.git",
    "created": "2026-04-06",
    "author": "QB_DESARROLLO",
    "ai_assistant": "Gemini 2.5 Pro via Antigravity (VS Code)"
  },

  "architecture": {
    "overview": "Flask web app for GHS chemical labeling, connected to SAP HANA and SQL Server. Both dev and pre-prod run on the same Windows machine.",
    "diagram": "SGA_dev (dev) → robocopy → SGAv1.01 (pre-prod) → SQL Server (192.168.2.237) + SAP HANA",
    "servers": {
      "development": {
        "host": "127.0.0.2",
        "port": 5001,
        "url": "http://127.0.0.2:5001/",
        "folder": "SGA_dev",
        "runner": "python sga_web/run_development.py",
        "wsgi": "Flask built-in (debug mode)"
      },
      "pre_production": {
        "host": "192.168.2.218",
        "port": 5000,
        "url": "http://192.168.2.218:5000/",
        "folder": "SGAv1.01",
        "runner": "python sga_web/run_production.py",
        "wsgi": "Waitress (6 threads)",
        "service": {
          "manager": "NSSM",
          "service_name": "SGA_PreProd",
          "startup_type": "SERVICE_AUTO_START"
        }
      },
      "sql_database": {
        "host": "192.168.2.237",
        "type": "SQL Server",
        "database": "SGA_Database",
        "driver": "ODBC Driver 17 for SQL Server",
        "note": "This is NOT the app server — only the database"
      },
      "sap_hana": {
        "host": "20.0.1.9",
        "port": 30015,
        "schema": "SBO_QUIMICABOSS",
        "driver": "hdbcli",
        "note": "Optional — app works without SAP connection"
      }
    }
  },

  "system_requirements": {
    "os": "Windows 10/11",
    "python": {
      "version": "3.11+",
      "current": "3.14.2",
      "note": "3.11 recommended for best compatibility. 3.14 works but some tools have encoding quirks"
    },
    "node": {
      "version": "18+",
      "current": "24.13.0",
      "purpose": "TailwindCSS build only (npm run build:css)"
    },
    "git": {
      "version": "2.40+",
      "current": "2.53.0"
    },
    "additional_software": [
      {
        "name": "ODBC Driver 17 for SQL Server",
        "purpose": "SQL Server connectivity via pyodbc",
        "download": "https://learn.microsoft.com/en-us/sql/connect/odbc/download-odbc-driver-for-sql-server"
      },
      {
        "name": "NSSM (Non-Sucking Service Manager)",
        "purpose": "Run pre-prod as a Windows service",
        "install": "winget install nssm"
      },
      {
        "name": "Poppler",
        "purpose": "PDF-to-image conversion for label previews",
        "note": "Place poppler-xx.xx.x folder in project root with Library/bin/ or bin/ subfolder"
      }
    ]
  },

  "setup_steps": {
    "1_clone_repository": {
      "command": "git clone https://github.com/Charly-bite/SGA_v1.0.git SGA_dev",
      "note": "Clone into a folder named SGA_dev"
    },
    "2_create_virtual_environment": {
      "commands": [
        "cd SGA_dev",
        "python -m venv .venv",
        ".venv\\Scripts\\activate"
      ]
    },
    "3_install_dependencies": {
      "production": "pip install -r requirements.txt",
      "development": "pip install -r requirements-dev.txt",
      "frontend": "cd sga_web && npm install && npm run build:css && cd .."
    },
    "4_configure_environment": {
      "command": "copy .env.example .env",
      "note": "Edit .env with real credentials for SAP, SQL Server, and printer",
      "required_variables": [
        "SAP_USER",
        "SAP_PASSWORD",
        "SQL_SERVER",
        "SQL_DATABASE",
        "SQL_USER",
        "SQL_PASSWORD",
        "PRINTER_IP",
        "PRINTER_NAME"
      ]
    },
    "5_configure_web_app_env": {
      "command": "copy sga_web\\.env.example sga_web\\.env",
      "note": "Web app has its own .env for Flask-specific settings"
    },
    "6_create_preprod_folder": {
      "note": "Create SGAv1.01 folder at same level as SGA_dev for pre-production deployment",
      "structure": "Desktop/SGA_dev (dev) and Desktop/SGAv1.01 (pre-prod)"
    },
    "7_verify_setup": {
      "run_tests": "python -m pytest tests/ -v",
      "start_dev": "python sga_web/run_development.py",
      "check_health": "curl http://127.0.0.2:5001/health"
    }
  },

  "git_workflow": {
    "branch_strategy": {
      "main": "Production-ready code. Pushes here trigger CI validation + release build",
      "development": "Integration branch. All feature work merges here first. CI runs on every push",
      "feature_branches": "feature/xyz — short-lived branches for specific work items"
    },
    "flow": "feature/* → development → main",
    "ci_triggers": {
      "push_to_development": "Runs: lint → test → security scan",
      "push_to_main": "Runs: full CI + builds release artifact",
      "pull_request_to_main": "Runs: full CI (must pass before merge)"
    }
  },

  "ci_cd_pipeline": {
    "platform": "GitHub Actions",
    "workflow_files": {
      "ci": ".github/workflows/ci.yml",
      "deploy": ".github/workflows/deploy.yml"
    },
    "ci_jobs": {
      "lint": {
        "tools": ["flake8", "black --check"],
        "config": {
          "max_line_length": 120,
          "ignored_rules": ["E501", "W503", "E402", "F401"]
        }
      },
      "test": {
        "tool": "pytest",
        "config_file": "pytest.ini",
        "test_directory": "tests/",
        "test_count": 13,
        "markers": {
          "slow": "Skip with -m 'not slow'",
          "integration": "Skip with -m 'not integration' (requires real DB/SAP)"
        },
        "environment_variables": {
          "SGA_ENV": "testing",
          "FLASK_ENV": "testing",
          "SQL_PASSWORD": "ci_test_password"
        }
      },
      "security": {
        "sast": {
          "tool": "bandit",
          "config_file": ".bandit.yaml",
          "severity_threshold": "medium",
          "skipped_rules": ["B101", "B110", "B311", "B404"]
        },
        "sca": {
          "tool": "pip-audit",
          "checks": "Known CVEs in dependencies"
        },
        "secrets": {
          "tool": "trufflehog",
          "github_action": "trufflesecurity/trufflehog@main",
          "scope": "Verified secrets only"
        }
      }
    },
    "deployment": {
      "method": "Local robocopy (both servers on same machine)",
      "script": "scripts/deploy.ps1",
      "steps": [
        "Pre-flight tests (pytest)",
        "Backup current pre-prod with timestamp",
        "Stop NSSM service",
        "Robocopy file sync with exclusions",
        "Start NSSM service",
        "Health check (http://192.168.2.218:5000/health)",
        "Auto-rollback if health check fails"
      ],
      "commands": {
        "full_deploy": ".\\scripts\\deploy.ps1",
        "dry_run": ".\\scripts\\deploy.ps1 -DryRun",
        "skip_tests": ".\\scripts\\deploy.ps1 -SkipTests"
      }
    }
  },

  "testing": {
    "framework": "pytest",
    "config_file": "pytest.ini",
    "fixtures_file": "tests/conftest.py",
    "test_files": {
      "tests/test_health.py": "3 tests — /health endpoint (status, JSON, diagnostics)",
      "tests/test_routes.py": "10 tests — Public routes, auth redirects, API JSON responses"
    },
    "run_commands": {
      "all_tests": "python -m pytest tests/ -v",
      "with_coverage": "python -m pytest tests/ -v --cov=sga_web --cov-report=term-missing",
      "skip_integration": "python -m pytest tests/ -v -m 'not integration'",
      "single_file": "python -m pytest tests/test_health.py -v"
    },
    "notes": [
      "Tests run WITHOUT real database or SAP connections",
      "CSRF is disabled in test mode (WTF_CSRF_ENABLED=False)",
      "The Windows stdout TextIOWrapper is skipped during pytest to avoid capture conflicts"
    ]
  },

  "security": {
    "local_scan_script": "scripts/security_scan.ps1",
    "gates": {
      "sast": {
        "tool": "bandit",
        "version": "1.9.4",
        "purpose": "Static analysis — finds SQL injection, XSS, hardcoded passwords",
        "run": "bandit -r sga_web/ --configfile .bandit.yaml --severity-level medium"
      },
      "sca": {
        "tool": "pip-audit",
        "purpose": "Dependency vulnerability scanning — checks for known CVEs",
        "run": "pip-audit -r requirements.txt"
      },
      "secrets": {
        "tool": "trufflehog (CI) / regex patterns (local)",
        "purpose": "Detect leaked API keys, passwords, tokens in source code"
      }
    },
    "critical_files_to_protect": [
      ".env (SAP/SQL credentials)",
      "sga_web/.env (Flask secrets)",
      "sga_web/.flask_secret_key",
      "users.json (user password hashes)",
      "db_client_config.json (database paths)"
    ]
  },

  "monitoring": {
    "health_endpoint": {
      "url": "/health",
      "returns": {
        "status": "ok",
        "version": "git short SHA",
        "environment": "development | testing | production",
        "db_connected": "boolean — is product database loaded",
        "sap_available": "boolean — is SAP HANA driver installed",
        "products_loaded": "number — count of loaded products"
      }
    },
    "request_logging": {
      "middleware": "sga_web/middleware/request_logger.py",
      "format": "METHOD /path → STATUS (duration_ms) [user=X, ip=Y]",
      "excludes": ["/static/", "/favicon.ico"]
    },
    "log_files": {
      "app_log": "logs/sga_app.log",
      "service_log": "logs/service.log (NSSM stdout)",
      "service_error_log": "logs/service_error.log (NSSM stderr)"
    }
  },

  "vscode_setup": {
    "recommended_extensions": [
      {
        "id": "ms-python.python",
        "name": "Python",
        "purpose": "Python language support, debugging, IntelliSense"
      },
      {
        "id": "ms-python.flake8",
        "name": "Flake8",
        "purpose": "Real-time linting in editor"
      },
      {
        "id": "ms-python.black-formatter",
        "name": "Black Formatter",
        "purpose": "Auto-format on save"
      },
      {
        "id": "google.gemini-code-assist",
        "name": "Gemini Code Assist",
        "purpose": "AI coding assistant"
      },
      {
        "id": "github.vscode-github-actions",
        "name": "GitHub Actions",
        "purpose": "View CI/CD pipeline status in VS Code"
      },
      {
        "id": "ms-vscode.vscode-node-azure-pack",
        "name": "Azure Tools",
        "purpose": "SQL Server management (optional)"
      }
    ],
    "settings": {
      "python.defaultInterpreterPath": ".venv/Scripts/python.exe",
      "python.testing.pytestEnabled": true,
      "python.testing.pytestArgs": ["tests/"],
      "editor.formatOnSave": true,
      "editor.defaultFormatter": "ms-python.black-formatter",
      "[python]": {
        "editor.defaultFormatter": "ms-python.black-formatter",
        "editor.formatOnSave": true
      },
      "flake8.args": ["--max-line-length=120", "--ignore=E501,W503,E402,F401"],
      "files.exclude": {
        "**/__pycache__": true,
        "**/.pytest_cache": true,
        "**/node_modules": true,
        "**/*.pyc": true
      }
    },
    "tasks": [
      {
        "label": "Run Dev Server",
        "command": "python sga_web/run_development.py",
        "group": "none"
      },
      {
        "label": "Run Tests",
        "command": "python -m pytest tests/ -v",
        "group": "test"
      },
      {
        "label": "Run Security Scan",
        "command": ".\\scripts\\security_scan.ps1",
        "group": "test"
      },
      {
        "label": "Deploy to Pre-Prod",
        "command": ".\\scripts\\deploy.ps1",
        "group": "none"
      },
      {
        "label": "Deploy to Pre-Prod (Dry Run)",
        "command": ".\\scripts\\deploy.ps1 -DryRun",
        "group": "none"
      },
      {
        "label": "Build CSS (Tailwind)",
        "command": "cd sga_web && npm run build:css",
        "group": "build"
      }
    ],
    "launch_configurations": [
      {
        "name": "SGA Dev Server",
        "type": "python",
        "request": "launch",
        "program": "sga_web/run_development.py",
        "env": {
          "SGA_ENV": "development",
          "DEV_HOST": "127.0.0.2",
          "DEV_PORT": "5001"
        }
      },
      {
        "name": "Run Tests",
        "type": "python",
        "request": "launch",
        "module": "pytest",
        "args": ["tests/", "-v"],
        "env": {
          "SGA_ENV": "testing"
        }
      }
    ]
  },

  "gemini_ai_config": {
    "assistant": "Gemini Code Assist / Antigravity",
    "instructions_file": ".github/copilot-instructions.md",
    "key_rules": [
      "Never start/restart dev server unless user explicitly asks",
      "SGA_dev is isolated from SGAv1.01 — never modify pre-prod files directly",
      "Wrap all SAP/SQL calls in try/except with logging",
      "Use os.path.join for all file paths",
      "CSV codes (H-codes, P-codes) must be enforced as str type",
      "Use SharedFileManager for concurrent file access",
      "Legacy Tkinter GUI is deprecated — web only"
    ],
    "devops_context": {
      "test_before_deploy": "Always run pytest before deploying",
      "health_check": "Verify /health endpoint after any deployment",
      "security_scan": "Run scripts/security_scan.ps1 before pushing sensitive changes",
      "branch_flow": "feature/* → development → main"
    }
  },

  "project_structure": {
    "SGA_dev/": {
      ".env": "Secrets (SAP/SQL credentials) — NEVER commit",
      ".env.example": "Template with placeholders",
      ".gitignore": "Prevents secrets/artifacts from being committed",
      ".bandit.yaml": "Security scanner configuration",
      "pytest.ini": "Test runner configuration",
      "requirements.txt": "Production Python dependencies",
      "requirements-dev.txt": "Dev/CI tools (includes requirements.txt)",
      "config.py": "Root-level SQL/SAP config loader",
      "scripts/": {
        "deploy.ps1": "Deploy DEV → PRE-PROD with health check + rollback",
        "security_scan.ps1": "Run all 3 security gates locally"
      },
      ".github/": {
        "workflows/ci.yml": "CI pipeline (lint + test + security)",
        "workflows/deploy.yml": "CD pipeline (validate + build release)",
        "copilot-instructions.md": "AI assistant context rules"
      },
      "tests/": {
        "conftest.py": "Shared test fixtures (Flask test client)",
        "test_health.py": "Health endpoint tests (3)",
        "test_routes.py": "Route smoke tests (10)"
      },
      "sga_web/": {
        "app.py": "Flask application factory (create_app)",
        "config.py": "Flask config classes (Dev/Prod/Testing)",
        "models.py": "User model for Flask-Login",
        "extensions.py": "Flask extensions (rate limiter)",
        "run_development.py": "Dev server launcher (127.0.0.2:5001)",
        "run_production.py": "Production server launcher (Waitress, 0.0.0.0:5000)",
        "middleware/": {
          "request_logger.py": "HTTP request logging middleware"
        },
        "routes/": {
          "auth.py": "Login/logout/password change",
          "main.py": "Dashboard and main pages",
          "labels.py": "GHS label generation",
          "products.py": "Product management",
          "orders.py": "Order tracking + SAP sync",
          "users.py": "User administration",
          "api.py": "REST API endpoints",
          "templates.py": "Label template designer",
          "control_interno.py": "Internal control panel"
        }
      }
    }
  },

  "installed_packages": {
    "production": {
      "Flask": "3.1.2",
      "Flask-Login": "0.6.3",
      "Flask-WTF": "1.2.2",
      "Flask-Limiter": "4.1.1",
      "waitress": "3.0.2",
      "python-dotenv": "1.2.1",
      "SQLAlchemy": "2.0.48",
      "pyodbc": "5.3.0",
      "hdbcli": "2.27.23",
      "pandas": "3.0.0",
      "reportlab": "4.4.9",
      "Pillow": "12.1.0",
      "Jinja2": "3.1.6",
      "Werkzeug": "3.1.5"
    },
    "development": {
      "pytest": "9.0.2",
      "pytest-cov": "7.1.0",
      "pytest-mock": "3.15.1",
      "flake8": "7.3.0",
      "bandit": "1.9.4"
    }
  }
}
