[flake8]
max-line-length = 120
ignore =
    E501,
    W503,
    E402,
    F401,
    E203,
    W291,
    W293,
    E226,
    E231,
    F841
exclude =
    .venv,
    __pycache__,
    .git,
    .ruff_cache,
    .pytest_cache,
    poppler-24.08.0,
    base_datos_actualizada,
    unified_db,
    unified_db_backup_*,
    original_data,
    *.pyc,
    Flow diagrams,
    Flujo_*
