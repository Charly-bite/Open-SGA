                                            event_date, user_name, merma_kg, notes
                                        )
                                        ON target.product_id = source.product_id 
                                           AND target.old_lote = source.old_lote 
                                           AND target.new_lote = source.new_lote
                                           AND target.event_date = source.event_date
                                        WHEN MATCHED THEN
