# ============================================
# SGA Environment Configuration Template
# ============================================
# Copy this file to .env and fill in real values.
# NEVER commit the .env file to git!

# SAP HANA Credentials
SAP_USER=SYSTEM
SAP_PASSWORD=your_sap_password_here
SAP_PASS=your_sap_password_here

# Database Server
DB_SERVER=192.168.2.237
DB_SHARE=SGA_Database

# Printer (TSC MB240)
PRINTER_IP=192.168.1.100
PRINTER_NAME=TSC MB240
PRINTER_PORT=9100

# Application Environment: development | production
SGA_ENV=development
SGA_LOG_LEVEL=INFO
DEV_HOST=127.0.0.2
DEV_PORT=5001

# SQL Server Credentials
SQL_SERVER=192.168.2.237
SQL_DATABASE=SGA_Database
SQL_USER=sga_app_user
SQL_PASSWORD=your_sql_password_here
SQL_TRUST_CERTIFICATE=no
